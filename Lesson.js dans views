<template>
  <div class="lesson-page">
    <h1>{{ lesson.title }}</h1>

    <div
      v-for="chapter in lesson.chapters" 
      :key="chapter.id" 
      class="chapter"
    >
      <div 
        class="chapter-title"
        @click="toggleChapter(chapter.id)"
      >
        {{ chapter.title }}
      </div>

      <div  
        v-if="activeChapter === chapter.id" 
        class="chapter-content"
      >
        {{ chapter.content }}
      </div>

    </div> <!-- ✅ fermeture du v-for -->

    <!-- ✅ boutons déplacés en dehors du v-for -->
    <div class="buttons">
      <button @click="$router.back()">⬅ Retour</button>

      <button 
        class="quiz-btn" 
        @click="$router.push(`/lesson/${lesson.id}/quiz`)"
      >
        Quiz
      </button>
    </div>

  </div>
</template>
<script setup>
import { lessons } from '../data/lessons.js'
import { useRoute } from 'vue-router'
import { ref } from 'vue'

const route = useRoute()
const lessonId = Number(route.params.id)

const lesson = lessons.find(l => l.id === lessonId)

const activeChapter = ref(null)

const toggleChapter = (id) => {
  activeChapter.value = activeChapter.value === id ? null : id
}
</script>

